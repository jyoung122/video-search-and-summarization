# =============================================================================
# AIMS — APP POD
# =============================================================================
# Runs DeepStream perception + behavior analytics + foundational services +
# vss-agent / vss-ui / alert-bridge on a single L4 (24 GB).
#
# VLM and LLM are remote: the app pod calls the NIM pod over the private
# network. Set NIM_POD_HOST to the NIM pod's reachable hostname/IP.
# =============================================================================

# --- Required: paths ---------------------------------------------------------
MDX_SAMPLE_APPS_DIR=/path/to/video-search-and-summarization/deployments
MDX_DATA_DIR=/path/to/metropolis-apps-data

# --- Required: networking ----------------------------------------------------
# Local host IP (for services on this pod that need a reachable address).
HOST_IP=
EXTERNAL_IP=${HOST_IP}

# Reachable address of the NIM pod from this pod (private network preferred).
NIM_POD_HOST=

# --- Required: API keys ------------------------------------------------------
# NGC not strictly required on the app pod (no local NIMs), but kept for
# tools that touch NGC-hosted images.
NGC_CLI_API_KEY=
NVIDIA_API_KEY=

# --- Deployment mode ---------------------------------------------------------
# 2d_cv: DeepStream CV (RT-DETR + GDINO) detects events; VLM verifies.
# 2d_vlm: continuous VLM analysis (NOT recommended for AIMS — costs more on
# the NIM pod and gives no benefit for accident alerting).
MODE=2d_cv
BP_PROFILE=bp_developer_alerts

# Hardware profile drives DeepStream / perception tuning. The L4 is closest
# to L40S (Ada Lovelace family) for engine/kernel selection.
HARDWARE_PROFILE=L40S

# --- GPU device IDs (single-GPU L4 = device 0 for everything) ---------------
RESERVED_DEVICE_IDS='0'
FIXED_SHARED_DEVICE_IDS=''
RT_CV_DEVICE_ID='0'
RT_VLM_DEVICE_ID='0'
# These are unused when *_MODE=remote, but kept defined to satisfy compose.
LLM_DEVICE_ID='0'
VLM_DEVICE_ID='0'

# --- Remote VLM / LLM (the whole point of this split) -----------------------
LLM_MODE=remote
VLM_MODE=remote

LLM_NAME=nvidia/nvidia-nemotron-nano-9b-v2
LLM_NAME_SLUG=nvidia-nemotron-nano-9b-v2
LLM_BASE_URL=http://${NIM_POD_HOST}:30081/v1
LLM_MODEL_TYPE=nim
LLM_ENV_FILE=

VLM_NAME=nvidia/cosmos-reason2-8b
VLM_NAME_SLUG=cosmos-reason2-8b
VLM_BASE_URL=http://${NIM_POD_HOST}:30082/v1
VLM_MODEL_TYPE=nim
VLM_ENV_FILE=

# RTVI VLM endpoint (used in 2d_vlm mode; harmless in 2d_cv).
RTVI_VLM_ENDPOINT=http://${NIM_POD_HOST}:30082/v1

# Proxy mode
PROXY_MODE='no_proxy'

# Compose profile selection — drives which alerts-profile services start.
# *_MODE=remote means no local NIM services are activated; only the app
# stack comes up.
COMPOSE_PROFILES=${BP_PROFILE}_${MODE},${BP_PROFILE}_${MODE}_${HARDWARE_PROFILE},${BP_PROFILE}_${MODE}_${PROXY_MODE},llm_${LLM_MODE}_${LLM_NAME_SLUG},vlm_${VLM_MODE}_${VLM_NAME_SLUG}

COMPOSE_PROJECT_NAME=aims-app

# --- Message broker ----------------------------------------------------------
STREAM_TYPE=kafka

# --- Perception --------------------------------------------------------------
MODEL_TYPE=cnn
MODEL_NAME_2D="GDINO"
PERCEPTION_IMAGE="nvcr.io/nvidia/vss-core/vss-rt-cv"
PERCEPTION_TAG="3.1.0"
PERCEPTION_DOCKERFILE_PREFIX=''

# Number of RTSP feeds the L4 will fan out to DeepStream.
# Bump up to ~30 for 1080p traffic feeds; back off if you see frame drops.
NUM_SENSORS=15

# --- Elasticsearch -----------------------------------------------------------
ELASTICSEARCH_ILM_MIN_AGE=4h
ELASTICSEARCH_CONNECTION_MAX_ATTEMPTS=20

# --- nvstreamer / VST --------------------------------------------------------
NVSTREAMER_INSTALL_ADDITIONAL_PACKAGES=true
NVSTREAMER_HTTP_PORT=31000

VST_PORT=30888
VST_EXTERNAL_URL=http://${EXTERNAL_IP}:${VST_PORT}
VST_INTERNAL_URL=http://${HOST_IP}:${VST_PORT}
VST_MCP_PORT=8001
VST_MCP_URL=http://${HOST_IP}:${VST_MCP_PORT}
VST_ADAPTOR=vst_rtsp
VST_MCP_IMAGE_TAG="3.1.0"
VST_STREAM_PROCESSOR_IMAGE_TAG="3.1.0"
VST_SENSOR_IMAGE_TAG="3.1.0"
NVSTREAMER_IMAGE_TAG="3.1.0"

# --- VLM-as-verifier ---------------------------------------------------------
VLM_AS_VERIFIER_CONFIG_FILE_PREFIX=''
VLM_AS_VERIFIER_CONFIG_FILE=${MDX_SAMPLE_APPS_DIR}/developer-workflow/dev-profile-alerts/vlm-as-verifier/configs/${VLM_AS_VERIFIER_CONFIG_FILE_PREFIX}config.yml
VLM_AS_VERIFIER_ALERT_TYPE_CONFIG_FILE=${MDX_SAMPLE_APPS_DIR}/developer-workflow/dev-profile-alerts/vlm-as-verifier/configs/alert_type_config.json

# --- NIM ports (used to construct *_BASE_URL above; do not change) ----------
LLM_PORT=30081
VLM_PORT=30082
VLM_NIM_KVCACHE_PERCENT="0.4"

# --- vss-agent ---------------------------------------------------------------
VSS_AGENT_VERSION=3.1.0
VSS_AGENT_CONFIG_FILE=./deployments/developer-workflow/dev-profile-alerts/vss-agent/configs/config.yml
VSS_AGENT_HOST=0.0.0.0
VSS_AGENT_PORT=8000
STREAM_MODE=other
VIDEO_ANALYSIS_MCP_URL=http://${HOST_IP}:9901
VSS_VA_MCP_CONFIG_FILE=./deployments/developer-workflow/dev-profile-alerts/vss-agent/configs/va_mcp_server_config.yml
VSS_VA_MCP_PORT=9901
VSS_AGENT_TEMPLATE_PATH=./deployments/developer-workflow/dev-profile-alerts/vss-agent/templates
VSS_AGENT_TEMPLATE_NAME=incident_report_template.md
MDX_PORT=8081

# --- RTVI (only used in 2d_vlm; left configured for completeness) -----------
RTVI_VLM_IMAGE_TAG="3.1.0"
RTVI_VLM_BASE_URL=http://${HOST_IP}:8018
RTVI_VLM_OPENAI_MODEL_DEPLOYMENT_NAME=${VLM_NAME}
RTVI_VLM_MODEL_TO_USE=openai-compat
RTVI_VLLM_GPU_MEMORY_UTILIZATION=''
RTVI_VLM_MODEL_PATH='ngc:nim/nvidia/cosmos-reason2-8b:hf-1208'
RTVI_VLM_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
RTVI_VLM_KAFKA_INCIDENT_TOPIC=mdx-vlm-incidents

# --- Storage / reports / telemetry ------------------------------------------
VSS_ES_PORT=9200
VSS_AGENT_OBJECT_STORE_TYPE=local_object_store
VSS_AGENT_REPORTS_BASE_URL=http://${EXTERNAL_IP}:${VSS_AGENT_PORT}/static/
VSS_AGENT_EXTERNAL_URL=http://${EXTERNAL_IP}:${VSS_AGENT_PORT}
PHOENIX_ENDPOINT=http://${HOST_IP}:6006

# --- UI ----------------------------------------------------------------------
NEXT_PUBLIC_APP_TITLE="AIMS"
NEXT_PUBLIC_APP_SUBTITLE="Traffic Accident Monitoring"
NEXT_PUBLIC_WORKFLOW="VSS Agent"
NEXT_PUBLIC_ENABLE_CHAT_TAB=true
NEXT_PUBLIC_CHAT_API_CUSTOM_AGENT_PARAMS_JSON={"params":[{"name":"llm_reasoning","label":"LLM Reasoning","type":"boolean","default-value":false,"changeable":true,"tooltip-info":""},{"name":"vlm_reasoning","label":"VLM Reasoning","type":"boolean","default-value":false,"changeable":true,"tooltip-info":""}]}
NEXT_PUBLIC_CHAT_UPLOAD_FILE_ENABLE=false
NEXT_PUBLIC_ENABLE_ALERTS_TAB=true
NEXT_PUBLIC_ALERTS_TAB_VERIFIED_FLAG_DEFAULT=true
NEXT_PUBLIC_ENABLE_DASHBOARD_TAB=false
NEXT_PUBLIC_ENABLE_MAP_TAB=false
NEXT_PUBLIC_ENABLE_VIDEO_MANAGEMENT_TAB=true
NEXT_PUBLIC_VIDEO_MANAGEMENT_TAB_ADD_RTSP_ENABLE=true
NEXT_PUBLIC_VIDEO_MANAGEMENT_VIDEO_UPLOAD_ENABLE=false
NEXT_PUBLIC_ENABLE_SEARCH_TAB=false
