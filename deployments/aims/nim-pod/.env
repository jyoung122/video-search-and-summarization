# =============================================================================
# AIMS — NIM POD
# =============================================================================
# Runs Cosmos-Reason2-8B (VLM) and Nemotron-Nano-9B-v2 (LLM) co-resident on a
# single RTX PRO 6000 Blackwell (96 GB), both BF16. App-pod calls these over
# the private network on ports 30081 (LLM) and 30082 (VLM).
# =============================================================================

# --- Required: paths ---------------------------------------------------------
# Absolute path to the cloned repo's deployments/ directory.
MDX_SAMPLE_APPS_DIR=/path/to/video-search-and-summarization/deployments

# --- Required: NGC credentials ----------------------------------------------
# Pulls model weights from NGC on first boot. Get from https://ngc.nvidia.com/
NGC_CLI_API_KEY=

# --- Hardware profile --------------------------------------------------------
HARDWARE_PROFILE=RTXPRO6000BW

# --- GPU placement -----------------------------------------------------------
# Both NIMs share GPU 0 in the *-shared.env profile variants.
SHARED_LLM_VLM_DEVICE_ID=0
LLM_DEVICE_ID=0
VLM_DEVICE_ID=0

# --- Model selection ---------------------------------------------------------
# BF16 variants (Blackwell supports both BF16 and FP8; we lock BF16 here).
LLM_NAME=nvidia/nvidia-nemotron-nano-9b-v2
LLM_NAME_SLUG=nvidia-nemotron-nano-9b-v2

VLM_NAME=nvidia/cosmos-reason2-8b
VLM_NAME_SLUG=cosmos-reason2-8b

# --- Modes -------------------------------------------------------------------
# local_shared = both models on the same GPU. The compose profiles below
# select the *-shared-gpu service variants which read hw-<profile>-shared.env.
LLM_MODE=local_shared
VLM_MODE=local_shared

# --- Ports (must match app-pod's *_BASE_URL) --------------------------------
LLM_PORT=30081
VLM_PORT=30082

# --- KV cache fraction for the VLM (rest is left to the LLM) ----------------
VLM_NIM_KVCACHE_PERCENT=0.4

# --- Optional: custom env overrides per NIM ---------------------------------
LLM_ENV_FILE=
VLM_ENV_FILE=
LLM_MODEL_TYPE=nim
VLM_MODEL_TYPE=nim

# --- Compose profile selection ----------------------------------------------
# These two profiles bring up the *-shared-gpu service variants of each NIM.
COMPOSE_PROFILES=vlm_${VLM_MODE}_${VLM_NAME_SLUG},llm_${LLM_MODE}_${LLM_NAME_SLUG}

COMPOSE_PROJECT_NAME=aims-nim
