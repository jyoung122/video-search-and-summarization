# AIMS demo — controller config.
# Copy to .env and fill in. .env is gitignored.
#
#   cp .env.example .env
#   chmod 600 .env

# --- REQUIRED ---------------------------------------------------------------
# NGC API key (https://ngc.nvidia.com/setup/api-key). Used by both pods to
# pull NIM images and weights from nvcr.io.
NGC_CLI_API_KEY=

# --- OPTIONAL: datacenter ---------------------------------------------------
# Must support both NVIDIA L4 and RTX PRO 6000 Blackwell with global
# networking. List with:  runpodctl datacenter list
AIMS_DC=EU-RO-1

# --- OPTIONAL: GPU selection ------------------------------------------------
# Override only if you want to test on different hardware.
# AIMS_GPU_NIM=NVIDIA RTX PRO 6000 Blackwell Server Edition
# AIMS_GPU_APP=NVIDIA L4

# --- OPTIONAL: feed count ---------------------------------------------------
# Number of RTSP streams DeepStream will fan out to. Bump up to ~30 for
# 1080p; back off if you see frame drops.
AIMS_NUM_SENSORS=15

# --- OPTIONAL: template overrides ------------------------------------------
# Defaults match the templates created by this repo. Override only if you
# regenerate them.
# AIMS_NIM_TEMPLATE=iyl91qhpsa
# AIMS_APP_TEMPLATE=juolcnzk4l

# --- OPTIONAL: state file ---------------------------------------------------
# Where pod IDs and the NIM private IP are persisted between commands.
# AIMS_STATE_FILE=$HOME/.aims-state.json
